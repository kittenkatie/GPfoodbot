def dish_text(cat_key, idx):
    d = MENU[cat_key]["items"][idx]
    tags = " · ".join(d["tags"]) if d["tags"] else ""
    vit = f"\n🧬 *Витамины:* {d['vit']}" if d["vit"] else ""
    tags_line = f"\n🏷 {tags}" if tags else ""
    return (
        f"{d['e']} *{d['name']}*\n"
        f"💰 {d['price']} ₽ · {d['w']}г\n\n"
        f"📝 {d['desc']}\n\n"
        f"📊 *КБЖУ на порцию:*\n"
        f"🔥 {d['cal']} ккал\n"
        f"💪 Белки: {d['p']}г\n"
        f"🫒 Жиры: {d['f']}г\n"
        f"🌾 Углеводы: {d['c']}г"
        f"{vit}{tags_line}"
    )

def combo_text(idx):
    c = COMBOS[idx]
    items_text = "\n".join([f"{e} {n} — {cal}" for e, n, cal in c["items"]])
    return (
        f"{c['icon']} *{c['name']}*\n"
        f"_{c['goal']}_\n\n"
        f"📊 {c['total']}\n\n"
        f"*Состав комбо:*\n{items_text}"
    )

def motiv_text():
    import datetime
    day = datetime.datetime.now().weekday()
    days = ["Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота", "Воскресенье"]
    text, tip = MOTIVATIONS[day % len(MOTIVATIONS)]
    return (
        f"⚡ *Мотивация · {days[day]}*\n\n"
        f"_{text}_\n\n"
        f"— команда Green Point\n\n"
        f"{tip}"
    )


