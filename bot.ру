def main_keyboard():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("📋 Меню", callback_data="menu"),
         InlineKeyboardButton("🎯 Подобрать комбо", callback_data="combos")],
        [InlineKeyboardButton("⚡ Мотивация дня", callback_data="motiv")],
    ])

def menu_keyboard():
    buttons = []
    row = []
    for key, cat in MENU.items():
        row.append(InlineKeyboardButton(f"{cat['icon']} {cat['label']}", callback_data=f"cat_{key}"))
        if len(row) == 2:
            buttons.append(row)
            row = []
    if row:
        buttons.append(row)
    buttons.append([InlineKeyboardButton("⬅️ Назад", callback_data="start")])
    return InlineKeyboardMarkup(buttons)

def category_keyboard(cat_key):
    cat = MENU[cat_key]
    buttons = []
    for i, dish in enumerate(cat["items"]):
        buttons.append([InlineKeyboardButton(
            f"{dish['e']} {dish['name']} — {dish['cal']} ккал",
            callback_data=f"dish_{cat_key}_{i}"
        )])
    buttons.append([InlineKeyboardButton("⬅️ Назад к меню", callback_data="menu")])
    return InlineKeyboardMarkup(buttons)

