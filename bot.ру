# ХЕНДЛЕРЫ
# ══════════════════════════════════════════
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = (
        "🌿 Привет! Я бот *Green Point* — сети кафе здорового питания.\n\n"
        "Покажу КБЖУ и состав любого блюда из реального меню, "
        "помогу выбрать одно из *16 комбо* под твою цель 💚\n\n"
        "Выбери раздел:"
    )
    if update.message:
        await update.message.reply_text(text, parse_mode="Markdown", reply_markup=main_keyboard())
    elif update.callback_query:
        await update.callback_query.edit_message_text(text, parse_mode="Markdown", reply_markup=main_keyboard())

async def button(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    data = query.data

    if data == "start":
        await start(update, context)

    elif data == "menu":
        await query.edit_message_text(
            "📋 *Меню Green Point*\n\nВыбери раздел 👇",
            parse_mode="Markdown", reply_markup=menu_keyboard()
        )

    elif data.startswith("cat_"):
        key = data[4:]
        cat = MENU[key]
        note = f"\n_*{cat['note']}_" if cat.get("note") else ""
        await query.edit_message_text(
            f"{cat['icon']} *{cat['label']}*{note}\n\nТапни на блюдо — покажу КБЖУ и состав 👇",
            parse_mode="Markdown", reply_markup=category_keyboard(key)
        )

    elif data.startswith("dish_"):
        _, cat_key, idx = data.split("_", 2)
        await query.edit_message_text(
            dish_text(cat_key, int(idx)),
            parse_mode="Markdown", reply_markup=dish_keyboard(cat_key)
        )

    elif data == "combos":
        await query.edit_message_text(
            "🎯 *16 комбо* из реального меню\n\nВыбери цель 👇",
            parse_mode="Markdown", reply_markup=combos_keyboard()
        )

    elif data.startswith("combo_"):
        idx = int(data[6:])
        await query.edit_message_text(
            combo_text(idx),
            parse_mode="Markdown", reply_markup=combo_keyboard()
        )

    elif data == "motiv":
        await query.edit_message_text(
            motiv_text(),
            parse_mode="Markdown", reply_markup=back_keyboard()
        )

async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await start(update, context)


# ══════════════════════════════════════════
# ЗАПУСК
# ══════════════════════════════════════════
def main():
    app = (
        Application.builder()
        .token(BOT_TOKEN)
        .build()
    )
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(button))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    logger.info("✅ Green Point Bot запущен!")
    app.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == "__main__":
    main()
